# Required: ClickHouse native protocol settings for non-Docker runtime paths
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=replace-with-secret
CLICKHOUSE_DATABASE=origo
CLICKHOUSE_NATIVE_SEND_RECEIVE_TIMEOUT_SECONDS=3600

# Required: ClickHouse HTTP protocol settings for non-Docker runtime paths (clickhouse-connect)
CLICKHOUSE_HTTP_PORT=8123

# Required: Slice 7 Docker runtime mapping vars (Docker-only)
ORIGO_DOCKER_CLICKHOUSE_HOST=clickhouse
ORIGO_DOCKER_CLICKHOUSE_PORT=9000
ORIGO_DOCKER_CLICKHOUSE_HTTP_PORT=8123
ORIGO_DOCKER_CLICKHOUSE_USER=default
ORIGO_DOCKER_CLICKHOUSE_PASSWORD=replace-with-secret
ORIGO_DOCKER_CLICKHOUSE_DATABASE=origo
ORIGO_DOCKER_DAGSTER_HOST=dagster-webserver
ORIGO_DOCKER_DAGSTER_PORT=14000
ORIGO_DOCKER_API_PORT=18000
ORIGO_DOCKER_OBJECT_STORE_PORT=19000
ORIGO_DOCKER_OBJECT_STORE_CONSOLE_PORT=19001
ORIGO_DOCKER_DAGSTER_GRAPHQL_URL=http://localhost:14000/graphql
ORIGO_DOCKER_API_BASE_URL=http://localhost:18000
ORIGO_DOCKER_EXPORT_ROOT_DIR=/workspace/storage/exports
ORIGO_DOCKER_ETF_ANOMALY_LOG_PATH=/workspace/storage/audit/etf-anomalies.jsonl

# Required: API guardrail env vars (S1)
ORIGO_INTERNAL_API_KEY=replace-with-internal-key
ORIGO_QUERY_MAX_CONCURRENCY=4
ORIGO_QUERY_MAX_QUEUE=32
ORIGO_ALIGNED_QUERY_MAX_CONCURRENCY=2
ORIGO_ALIGNED_QUERY_MAX_QUEUE=16
ORIGO_ALIGNED_FRESHNESS_MAX_AGE_SECONDS=86400
ORIGO_ETF_QUERY_SERVING_STATE=shadow
ORIGO_FRED_QUERY_SERVING_STATE=shadow
ORIGO_ETF_DAILY_STALE_MAX_AGE_DAYS=2
ORIGO_FRED_SOURCE_PUBLISH_STALE_MAX_AGE_DAYS=2
ORIGO_FRED_ALERT_AUDIT_LOG_PATH=./storage/audit/fred-alert-events.jsonl
ORIGO_FRED_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace/replace
ORIGO_FRED_DISCORD_TIMEOUT_SECONDS=10
ORIGO_AUDIT_LOG_RETENTION_DAYS=365
ORIGO_CANONICAL_RUNTIME_AUDIT_LOG_PATH=./storage/audit/canonical-runtime-events.jsonl
ORIGO_CANONICAL_RUNTIME_AUDIT_MODE=summary
ORIGO_STREAM_QUARANTINE_STATE_PATH=./storage/audit/stream-quarantine-state.json
ORIGO_BACKFILL_MANIFEST_LOG_PATH=./storage/audit/backfill-partition-manifest.jsonl
ORIGO_S34_BACKFILL_CONCURRENCY=15
ORIGO_S34_FRED_RECONCILE_MAX_PARTITIONS_PER_RUN=730
ORIGO_S34_FRED_RECONCILE_MAX_SOURCE_WINDOW_DAYS=730

# Required: Dagster GraphQL dispatch env vars for raw export (S2)
ORIGO_DAGSTER_GRAPHQL_URL=http://localhost:4000/graphql
ORIGO_DAGSTER_REPOSITORY_NAME=__repository__
ORIGO_DAGSTER_LOCATION_NAME=origo_control_plane.definitions
ORIGO_DAGSTER_EXPORT_JOB_NAME=origo_raw_export_native_job
ORIGO_ETF_DAILY_SCHEDULE_CRON="0 2 * * *"
ORIGO_ETF_DAILY_SCHEDULE_TIMEZONE=UTC
ORIGO_ETF_DAILY_RETRY_MAX_ATTEMPTS=3
ORIGO_ETF_DAILY_RETRY_SENSOR_MIN_INTERVAL_SECONDS=300
ORIGO_ETF_ANOMALY_LOG_PATH=./storage/audit/etf-anomalies.jsonl
ORIGO_ETF_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/replace/replace
ORIGO_ETF_ALERT_SENSOR_MIN_INTERVAL_SECONDS=60
ORIGO_ETF_DISCORD_TIMEOUT_SECONDS=10
ORIGO_EXPORT_ROOT_DIR=./storage/exports
ORIGO_EXPORT_MAX_CONCURRENCY=2
ORIGO_EXPORT_MAX_QUEUE=16
ORIGO_SOURCE_RIGHTS_MATRIX_PATH=./contracts/source-rights-matrix.json
ORIGO_EXPORT_AUDIT_LOG_PATH=./storage/audit/export-events.jsonl

# Required: Scraper raw-artifact object-store settings (S3)
# Docker stack default is http://object-store:9000; host-run proofs may override to http://localhost:19000.
ORIGO_OBJECT_STORE_ENDPOINT_URL=http://object-store:9000
ORIGO_OBJECT_STORE_ACCESS_KEY_ID=origo
ORIGO_OBJECT_STORE_SECRET_ACCESS_KEY=origo-secret
ORIGO_OBJECT_STORE_BUCKET=origo-raw-artifacts
ORIGO_OBJECT_STORE_REGION=us-east-1

# Required: Scraper guardrail settings (S3)
ORIGO_SCRAPER_FETCH_MAX_ATTEMPTS=3
ORIGO_SCRAPER_FETCH_BACKOFF_INITIAL_SECONDS=1.0
ORIGO_SCRAPER_FETCH_BACKOFF_MULTIPLIER=2.0
ORIGO_SCRAPER_AUDIT_LOG_PATH=./storage/audit/scraper-events.jsonl

# Required: FRED source settings (S6)
FRED_API_KEY=replace-with-fred-api-key
ORIGO_FRED_HTTP_TIMEOUT_SECONDS=20
ORIGO_FRED_REVISION_HISTORY_INITIAL_VINTAGE_DATES_PER_REQUEST=275

# Required: Bitcoin Core source settings (S13, mainnet unpruned node)
# Docker stack default is http://bitcoin-core:8332; local host default is http://localhost:8332.
ORIGO_BITCOIN_CORE_RPC_URL=http://bitcoin-core:8332
ORIGO_BITCOIN_CORE_RPC_USER=origo-bitcoin-rpc
ORIGO_BITCOIN_CORE_RPC_PASSWORD=replace-with-rpc-password
ORIGO_BITCOIN_CORE_NETWORK=main
ORIGO_BITCOIN_CORE_RPC_TIMEOUT_SECONDS=30
ORIGO_BITCOIN_CORE_HEADERS_START_HEIGHT=0
ORIGO_BITCOIN_CORE_HEADERS_END_HEIGHT=100
# Required: server mount target for Bitcoin Core chainstate (must be on high-capacity disk)
ORIGO_BITCOIN_CORE_DATA_DIR=/mnt/origo-bitcoin-core-data
# Optional: pin a specific host disk by-id for Bitcoin Core data partition provisioning.
# Must be full /dev/disk/by-id/<name> symlink path (empty = auto-detect first >=3TB disk with >=500GiB free space).
ORIGO_BITCOIN_CORE_DATA_DISK_BY_ID=

# Required: server mount target for ClickHouse data (must be on high-capacity disk)
ORIGO_CLICKHOUSE_DATA_DIR=/mnt/origo-clickhouse-data
# Optional: pin a specific host disk by-id for ClickHouse data partition provisioning.
# Must be full /dev/disk/by-id/<name> symlink path (empty = auto-detect first eligible >=3TB disk, preferring non-Bitcoin disk).
ORIGO_CLICKHOUSE_DATA_DISK_BY_ID=
