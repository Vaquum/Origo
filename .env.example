# Required: ClickHouse native protocol settings (clickhouse-driver + migrations)
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=replace-with-secret
CLICKHOUSE_DATABASE=origo

# Required: ClickHouse HTTP protocol settings (clickhouse-connect)
CLICKHOUSE_HTTP_PORT=8123

# Optional aliases for client-side `origo/data` consumers.
# If omitted, client code falls back to the CLICKHOUSE_* values above.
# ORIGO_CLICKHOUSE_HOST=clickhouse
# ORIGO_CLICKHOUSE_PORT=8123
# ORIGO_CLICKHOUSE_USER=default
# ORIGO_CLICKHOUSE_PASSWORD=replace-with-secret
# ORIGO_CLICKHOUSE_DATABASE=origo

# Required: API guardrail env vars (S1)
ORIGO_INTERNAL_API_KEY=replace-with-internal-key
ORIGO_QUERY_MAX_CONCURRENCY=4
ORIGO_QUERY_MAX_QUEUE=32
